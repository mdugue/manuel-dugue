{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun run lint)",
      "Bash(bun run tsc)",
      "Bash(bun run test *)",
      "Read(~/.zshrc)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "companyAnnouncements": ["Reminder: Code reviews required for all PRs"]
}
